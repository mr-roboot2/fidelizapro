APP_NAME=FidelizaPro
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=America/Sao_Paulo
APP_URL=http://localhost/fidelizapro/public

# Em produção: APP_ENV=production, APP_DEBUG=false, LOG_LEVEL=warning, SESSION_ENCRYPT=true

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_BR

LOG_CHANNEL=daily
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=fidelizapro
# Em produção: crie um usuário dedicado com privilégios mínimos. NÃO use root sem senha.
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# null = deduz pelo APP_ENV (true em production, false em local)
SESSION_SECURE_COOKIE=null
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=file
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="naoresponda@fidelizapro.com.br"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8000,127.0.0.1,127.0.0.1:8000
# Tempo de vida dos tokens em minutos (43200 = 30 dias). Vazio = sem expiração.
SANCTUM_EXPIRATION=43200

# CORS — lista CSV de origens permitidas para api/*. Default = APP_URL.
# Em produção: CORS_ALLOWED_ORIGINS=https://meu-dominio.com.br
# CORS_ALLOWED_ORIGINS=

# Integração WhatsApp (preparado para futuro)
WHATSAPP_PROVIDER=mock
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
WHATSAPP_INSTANCE=

# Integração PDV (preparado para futuro)
PDV_WEBHOOK_SECRET=

# Gateway de pagamento (SaaS) — chave/token configurados na tela super admin.
# O token de webhook (asaas-access-token) é configurado em
# configuracoes_sistema.asaas_webhook_token via painel super admin e deve
# corresponder ao valor cadastrado no painel do Asaas.
ASAAS_API_KEY=
ASAAS_ENV=sandbox
